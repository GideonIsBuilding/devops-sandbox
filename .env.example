# DevOps Sandbox Platform — Environment Configuration
# Copy this to .env and adjust as needed.
# NEVER commit .env to version control.

# ── Network ──────────────────────────────────────────────────────────
NGINX_PORT=80
API_PORT=5000
PLATFORM_NETWORK=sandbox-platform

# ── Docker ───────────────────────────────────────────────────────────
NGINX_CONTAINER=sandbox-nginx
DEMO_IMAGE=sandbox-demo-app

# ── Sandbox defaults ─────────────────────────────────────────────────
SANDBOX_DEFAULT_TTL=1800        # seconds (30 minutes)
CLEANUP_INTERVAL=60             # seconds between daemon sweeps

# ── Health monitor ───────────────────────────────────────────────────
HEALTH_POLL_INTERVAL=30         # seconds between health polls
HEALTH_FAILURE_THRESHOLD=3      # consecutive failures before "degraded"
HEALTH_REQUEST_TIMEOUT=5        # seconds per HTTP request
